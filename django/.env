# D2 Django
D2_SECRET_KEY=change-me-d2-secret-key-development-only
D2_DB_PASSWORD=d2_pass

# Keycloak connection (internal Docker network name)
KEYCLOAK_SERVER_URL=http://keycloak:8080
KEYCLOAK_REALM=tools-realm

# PL OIDC client (matches keycloak/realm-export.json)
PL_OIDC_CLIENT_ID=pl-client
PL_OIDC_CLIENT_SECRET=pl-client-dev-secret
D2_REDIRECT_URI=http://localhost:8002/oidc/callback/
